 &lt;td style="text-align: center"&gt;&lt;a href="https://pigsty.cc/docs/pgsql/kernel/cloudberry"&gt;&lt;strong&gt;Cloudberry&lt;/strong&gt;&lt;/a&gt;&lt;/td&gt;
 &lt;td style="text-align: center"&gt;&lt;strong&gt;开源 MPP 数仓&lt;/strong&gt;&lt;/td&gt;
