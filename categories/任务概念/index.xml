&lt;/span&gt;&lt;/span&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;2025-07-15 01:37:31.403 P00 INFO: backup &lt;span class="nb"&gt;command&lt;/span&gt; end: completed successfully &lt;span class="o"&gt;(&lt;/span&gt;1099ms&lt;span class="o"&gt;)&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;
